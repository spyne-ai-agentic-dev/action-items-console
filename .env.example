# Action Items Console — backend creds (server-side only; never exposed to the browser).
# Copy to `.env.local` and fill in. The proxy picks the set matching the URL's ?env=.
#
#   ?env=prod  → PROD_*      ?env=uat → UAT_*      (?env=stag → STAG_*, optional)
# Any missing *_* value falls back to the corresponding PROD_* value.

# ── Production ──────────────────────────────────────────────────────────────
PROD_AI_API_BASE_URL=https://api.spyne.ai
PROD_AI_BEARER_TOKEN=__set_me__
PROD_ENTERPRISE_ID=__optional_default_enterprise__
PROD_TEAM_ID=__optional_default_team__

# ── UAT ─────────────────────────────────────────────────────────────────────
UAT_AI_API_BASE_URL=https://uat-api.spyne.xyz
UAT_AI_BEARER_TOKEN=__set_me__
UAT_ENTERPRISE_ID=__optional_default_enterprise__
UAT_TEAM_ID=__optional_default_team__

# ── Staging (optional) ──────────────────────────────────────────────────────
# STAG_AI_API_BASE_URL=
# STAG_AI_BEARER_TOKEN=
# STAG_ENTERPRISE_ID=
# STAG_TEAM_ID=
