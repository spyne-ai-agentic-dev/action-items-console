# Action Items Console — backend config (server-side only; never exposed to the browser).
#
# ENV is DERIVED from the base URL (converse-ai getIframeEnv contract):
#   uat-api.spyne.xyz → uat   ·   beta-api.spyne.xyz → stag   ·   api.spyne.ai → prod
#
# Set ONE backend + its bearer for the deployment:
APP_BACKEND_BASEURL=https://uat-api.spyne.xyz
AI_BEARER_TOKEN=__set_me__

# Optional default rooftop when the URL omits ?enterprise_id / ?team_id:
# ENTERPRISE_ID=
# TEAM_ID=

# ── Legacy fallback (still honored, keyed by the derived env) ────────────────
# If APP_BACKEND_BASEURL is unset, these per-env vars are used:
#   UAT_AI_API_BASE_URL / UAT_AI_BEARER_TOKEN
#   PROD_AI_API_BASE_URL / PROD_AI_BEARER_TOKEN
